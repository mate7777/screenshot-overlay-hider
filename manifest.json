{
  "manifest_version": 3,
  "name": "No Axeptio",
  "version": "1.0",
  "description": "Toggles temporary CSS hiding for screenshot and visual QA overlays.",
  "permissions": ["scripting", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "No Axeptio",
    "default_icon": {
      "16": "icon-active-16.png",
      "48": "icon-active-48.png",
      "128": "icon-active-128.png"
    }
  }
}
